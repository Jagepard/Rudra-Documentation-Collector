#!/usr/bin/php
<?php

if (php_sapi_name() !== "cli") exit;

$autoLoadPaths = [
    __DIR__ . '/vendor/autoload.php', 
    __DIR__ . '/../vendor/autoload.php', 
    __DIR__ . '/../../../autoload.php'
];

foreach($autoLoadPaths as $autoloader) {
    if( file_exists($autoloader) ) {
        require $autoloader;
        break;
    }
}

use Rudra\Cli\ConsoleFacade as Cli;
use Rudra\Markdown\Command\MakeDocumentation;

parse_str(implode('&', array_slice($argv, 1)), $inputArgs);

$commandName = 'make:docs';
Cli::addCommand($commandName, [MakeDocumentation::class]);
parse_str(implode('&', array_slice($argv, 1)), $inputArgs);
if (empty($inputArgs)) {
    $inputArgs = [$commandName => ''];
}

Cli::invoke($inputArgs);
